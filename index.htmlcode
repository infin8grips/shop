<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Simple Shop</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <style>
    :root {
      --bg: #f5f5f7;
      --card-bg: #ffffff;
      --accent: #1a73e8;
      --accent-dark: #1458b0;
      --text: #222222;
      --muted: #777777;
      --border: #e0e0e0;
      --radius: 10px;
      --shadow: 0 8px 16px rgba(0,0,0,0.06);
    }

    * { box-sizing: border-box; }

    body {
      margin: 0;
      font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      background: var(--bg);
      color: var(--text);
      display: flex;
      min-height: 100vh;
    }

    .layout {
      display: flex;
      width: 100%;
      max-width: 1200px;
      margin: 0 auto;
      padding: 24px;
      gap: 24px;
    }

    header {
      width: 100%;
      max-width: 1200px;
      margin: 0 auto;
      padding: 24px 24px 0 24px;
    }

    .title-row {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      gap: 16px;
    }

    h1 {
      margin: 0;
      font-weight: 500;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      font-size: 18px;
    }

    .subtitle {
      margin: 4px 0 0;
      color: var(--muted);
      font-size: 14px;
    }

    .items-panel {
      flex: 3;
      background: var(--card-bg);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
      padding: 20px;
      display: flex;
      flex-direction: column;
      min-height: 400px;
    }

    .items-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(170px, 1fr));
      gap: 16px;
      margin-bottom: 16px;
    }

    .item-card {
      background: #fafafa;
      border-radius: 12px;
      padding: 14px;
      border: 1px solid var(--border);
      display: flex;
      flex-direction: column;
      gap: 6px;
      transition: box-shadow 0.2s ease, transform 0.2s ease, border-color 0.2s ease;
    }

    .item-card:hover {
      box-shadow: 0 10px 20px rgba(0,0,0,0.08);
      transform: translateY(-1px);
      border-color: #d0d0d0;
    }

    /* Thumbnail area */
    .item-thumb-wrapper {
      width: 100%;
      aspect-ratio: 4 / 3;
      border-radius: 10px;
      overflow: hidden;
      background: #e9e9ee;
      margin-bottom: 10px;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .item-thumb {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    .item-name {
      font-size: 14px;
      font-weight: 500;
    }

    .item-desc {
      font-size: 12px;
      color: var(--muted);
      min-height: 32px;
    }

    .item-footer {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-top: 6px;
    }

    .price {
      font-weight: 600;
      font-size: 14px;
    }

    .item-actions {
      display: flex;
      align-items: center;
      gap: 4px;
    }

    .qty-input {
      width: 42px;
      padding: 3px 4px;
      font-size: 12px;
      border-radius: 6px;
      border: 1px solid var(--border);
      text-align: center;
    }

    button {
      border: none;
      cursor: pointer;
      border-radius: 999px;
      font-size: 12px;
      padding: 6px 12px;
      transition: background 0.2s ease, transform 0.1s ease, box-shadow 0.1s ease;
    }

    button:active {
      transform: translateY(1px);
      box-shadow: none;
    }

    .btn-primary {
      background: var(--accent);
      color: #ffffff;
      box-shadow: 0 6px 12px rgba(26,115,232,0.35);
    }

    .btn-primary:hover {
      background: var(--accent-dark);
    }

    .btn-outline {
      background: transparent;
      color: var(--accent);
      border: 1px solid var(--accent);
      padding-inline: 10px;
    }

    .pagination {
      margin-top: auto;
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding-top: 8px;
      border-top: 1px solid var(--border);
      font-size: 13px;
    }

    .cart-panel {
      flex: 1.4;
      background: var(--card-bg);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
      padding: 18px;
      display: flex;
      flex-direction: column;
      max-height: calc(100vh - 120px);
      position: sticky;
      top: 24px;
    }

    .cart-title-row {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      margin-bottom: 8px;
    }

    .cart-items {
      flex: 1;
      overflow-y: auto;
      padding-right: 4px;
      margin-bottom: 8px;
      border-top: 1px solid var(--border);
      border-bottom: 1px solid var(--border);
    }

    .cart-empty {
      font-size: 13px;
      color: var(--muted);
      margin: 12px 0;
    }

    .cart-item {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 8px 0;
      font-size: 13px;
      border-bottom: 1px dashed #eee;
    }

    .cart-item:last-child {
      border-bottom: none;
    }

    .cart-item-main {
      display: flex;
      flex-direction: column;
      gap: 2px;
    }

    .cart-item-name {
      font-weight: 500;
    }

    .cart-item-meta {
      color: var(--muted);
      font-size: 12px;
    }

    .cart-item-actions {
      display: flex;
      flex-direction: column;
      align-items: flex-end;
      gap: 4px;
    }

    .cart-total-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin: 10px 0 12px;
      font-size: 14px;
    }

    .cart-total-label {
      color: var(--muted);
    }

    .cart-total-value {
      font-size: 18px;
      font-weight: 600;
    }

    .cart-footer {
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    .badge {
      font-size: 11px;
      padding: 2px 8px;
      border-radius: 99px;
      background: #eef4ff;
      color: var(--accent);
    }

    .note {
      font-size: 11px;
      color: var(--muted);
      line-height: 1.4;
    }

    .text-link {
      color: var(--accent);
      text-decoration: none;
    }

    .text-link:hover {
      text-decoration: underline;
    }

    @media (max-width: 900px) {
      body {
        display: block;
      }

      header {
        padding: 16px 16px 0 16px;
      }

      .layout {
        flex-direction: column;
        padding: 16px;
      }

      .cart-panel {
        position: static;
        max-height: none;
      }
    }
  </style>
</head>
<body>
  <header>
    <div class="title-row">
      <div>
        <h1>Storefront</h1>
        <p class="subtitle">Browse items, add them to your cart, and checkout securely.</p>
      </div>
      <span id="cart-count-badge" class="badge">0 items</span>
    </div>
  </header>

  <main class="layout">
    <section class="items-panel">
      <div id="items-grid" class="items-grid"></div>
      <div class="pagination">
        <div>
          <button id="prev-page" class="btn-outline">&larr; Previous</button>
          <button id="next-page" class="btn-outline">Next &rarr;</button>
        </div>
        <div id="page-info"></div>
      </div>
    </section>

    <aside class="cart-panel">
      <div class="cart-title-row">
        <h2 style="margin:0;font-size:16px;">Cart</h2>
        <button id="clear-cart" class="btn-outline" style="font-size:11px;padding-inline:8px;">Clear</button>
      </div>

      <div id="cart-items" class="cart-items">
        <p class="cart-empty">Your cart is empty.</p>
      </div>

      <div class="cart-total-row">
        <span class="cart-total-label">Total</span>
        <span id="cart-total" class="cart-total-value">$0.00</span>
      </div>

      <div class="cart-footer">
        <button id="checkout-btn" class="btn-primary">Checkout with Square</button>
        <p class="note">
          On checkout, your order total and line items are sent to your server,
          which creates a Square checkout session or Web Payments charge and redirects you to Square’s secure payment page.
        </p>
      </div>
    </aside>
  </main>

  <script>
    // --- SAMPLE DATA: replace with your own items or fetch from API ---
    const ITEMS_PER_PAGE = 10;
    const allItems = Array.from({ length: 30 }, (_, i) => ({
      id: "item-" + (i + 1),
      name: "Product " + (i + 1),
      description: "A short description of product " + (i + 1) + ".",
      priceCents: 1999 + i * 100, // example pricing
      thumbnailUrl: "https://via.placeholder.com/320x200?text=Item+" + (i + 1)
    }));

    const state = {
      page: 1,
      cart: {} // { itemId: { ...item, qty } }
    };

    function formatMoney(cents) {
      return "$" + (cents / 100).toFixed(2);
    }

    // --- RENDER ITEMS ---

    function renderItems() {
      const grid = document.getElementById("items-grid");
      grid.innerHTML = "";

      const start = (state.page - 1) * ITEMS_PER_PAGE;
      const pageItems = allItems.slice(start, start + ITEMS_PER_PAGE);

      pageItems.forEach(item => {
        const card = document.createElement("div");
        card.className = "item-card";

        const thumbWrapper = document.createElement("div");
        thumbWrapper.className = "item-thumb-wrapper";

        const img = document.createElement("img");
        img.className = "item-thumb";
        img.src = item.thumbnailUrl;
        img.alt = item.name;

        thumbWrapper.appendChild(img);
        card.appendChild(thumbWrapper);

        const name = document.createElement("div");
        name.className = "item-name";
        name.textContent = item.name;

        const desc = document.createElement("div");
        desc.className = "item-desc";
        desc.textContent = item.description;

        const footer = document.createElement("div");
        footer.className = "item-footer";

        const price = document.createElement("span");
        price.className = "price";
        price.textContent = formatMoney(item.priceCents);

        const actions = document.createElement("div");
        actions.className = "item-actions";

        const qtyInput = document.createElement("input");
        qtyInput.type = "number";
        qtyInput.min = "1";
        qtyInput.value = "1";
        qtyInput.className = "qty-input";

        const addBtn = document.createElement("button");
        addBtn.className = "btn-primary";
        addBtn.textContent = "Add";

        addBtn.addE
